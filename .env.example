# Trading Bot Environment Variables
# Copy this file to .env and fill in your values

# HyperLiquid wallet private key (required for HL bots)
# Export from your wallet - DO NOT share this key
HL_SECRET_KEY=your_private_key_here

# MoonDev API key for liquidation data (optional)
MOONDEV_API_KEY=your_moondev_api_key_here

# Alpaca API keys (required for Alpaca bots)
# Get from https://app.alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# OpenRouter API key (required for AI swarm validation)
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
