[Unit]
Description=Kronos Price Collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=agent
WorkingDirectory=/home/agent/kronos-trading/collectors
ExecStart=/usr/bin/python3 /home/agent/kronos-trading/collectors/price_collector.py
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal

MemoryMax=1G
CPUQuota=50%

[Install]
WantedBy=multi-user.target
