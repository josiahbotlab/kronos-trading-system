[Unit]
Description=Stock Trading Daily Summary
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/agent/stock-trading
ExecStart=/usr/bin/python3 /home/agent/stock-trading/scripts/daily_summary.py
Environment="PATH=/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=/home/agent/stock-trading/.env

[Install]
WantedBy=default.target
